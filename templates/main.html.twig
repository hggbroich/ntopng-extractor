{% extends '@Common/main.html.twig' %}

{% block menu %}
    {{ knp_menu_render('mainMenu', {'currentClass': 'active' }) }}
{% endblock %}

{% block submenu %}
    {{ knp_menu_render('mainMenu', {'currentClass': 'active', 'template': '@Common/submenu.html.twig' }) }}
{% endblock %}

{% block container %}
    <div class="d-none d-md-block">
        {% block breadcrumb %}{% endblock %}
    </div>

    {% for msg in app.session.flashbag.get('error') %}
        <div class="bs-callout bs-callout-danger">
            <h5>{{ 'error.label'|trans }}</h5>
            <p>{{ msg|trans }}</p>
        </div>
    {% endfor %}

    {% for msg in app.session.flashbag.get('info') %}
        <div class="bs-callout bs-callout-info">
            <h5>{{ 'info.label'|trans }}</h5>
            <p>{{ msg|trans }}</p>
        </div>
    {% endfor %}

    {% for msg in app.session.flashbag.get('success') %}
        <div class="bs-callout bs-callout-success">
            <h5>{{ 'success.label'|trans }}</h5>
            <p>{{ msg|trans }}</p>
        </div>
    {% endfor %}

    {% block content %}{% endblock %}

    <div class="d-show d-md-none">
        {{ block('breadcrumb') }}
    </div>
{% endblock %}

{% block css %}
    <link rel="stylesheet" href="{{ preload(asset('bundles/common/app.css')) }}" type="text/css">
    <link rel="stylesheet" href="{{ preload(asset('vendor/@fortawesome/fontawesome-free/css/all.css')) }}" type="text/css">
{% endblock %}

{% block javascript %}
    <script src="{{ preload(asset('polyfill.js')) }}"></script>
    <script src="{{ preload(asset('menu.js')) }}"></script>
    <script src="{{ preload(asset('dropdown-polyfill.js')) }}"></script>

    {% block importmap %}
        {{ importmap(['app']) }}
    {% endblock %}
{% endblock %}
